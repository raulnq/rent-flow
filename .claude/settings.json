{
  "permissions": {
    "allow": [
      "Bash(pnpm run lint*)",
      "Bash(pnpm run format*)",
      "Bash(pnpm run build*)",
      "Bash(pnpm run dev*)",
      "Bash(pnpm run test*)",
      "Bash(pnpm run database:generate*)",
      "Bash(pnpm run database:migrate*)",
      "Bash(pnpm run database:studio*)",
      "Bash(pnpm exec drizzle-kit*)",
      "Bash(pnpm exec prettier*)",
      "Bash(pnpm exec tsc*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git branch*)",
      "Bash(git checkout -b*)",
      "Bash(git push*)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(pnpm install*)",
      "Bash(pnpm add*)",
      "Bash(pnpm test:*)",
      "Bash(for f:*)",
      "Bash(do echo:*)",
      "Read(//c/Source/rent-flow/**)",
      "Bash(done)",
      "Bash(grep -E \"\\\\.\\(tsx|ts\\)$\")",
      "Bash(grep -E \"\\\\.tsx$\")",
      "Bash(xargs grep:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \".claude\\work_complete.ps1\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && pnpm exec prettier --write \"$CLAUDE_FILE_PATH\""
          }
        ]
      }
    ]
  }
}
