{
  "name": "node-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm:dev:backend\" \"pnpm:dev:frontend\"",
    "dev:backend": "pnpm --filter @node-monorepo/backend dev",
    "dev:frontend": "pnpm --filter @node-monorepo/frontend dev",
    "build:backend": "pnpm --filter @node-monorepo/backend build",
    "build:frontend": "pnpm --filter @node-monorepo/frontend build",
    "build": "pnpm run build:backend && pnpm run build:frontend",
    "start:backend": "pnpm --filter @node-monorepo/backend start",
    "preview:frontend": "pnpm --filter @node-monorepo/frontend preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:format": "pnpm run lint:fix && pnpm run format",
    "prepare": "husky || true",
    "commit": "commit",
    "database:up": "docker-compose up database -d",
    "database:down": "docker-compose down database",
    "database:stop": "docker-compose stop database",
    "storage:up": "docker-compose up storage -d",
    "storage:down": "docker-compose down storage",
    "storage:stop": "docker-compose stop storage",
    "seq:up": "docker-compose up seq -d",
    "env:up": "pnpm run database:up && pnpm run storage:up",
    "env:stop": "pnpm run database:stop && pnpm run storage:stop",
    "storage:public": "docker exec -it rent-flow-storage-1 sh -c \"mc alias set local http://localhost:9000 minioadmin minioadmin && mc anonymous set download local/$1\" --"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@commitlint/prompt-cli": "^20.3.1",
    "@eslint/js": "^9.18.0",
    "@types/node": "^25.0.9",
    "concurrently": "^9.1.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0"
  }
}
